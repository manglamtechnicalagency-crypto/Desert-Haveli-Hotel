VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_R2_PUBLIC_BASE_URL=https://media.example.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=desert-haveli-media
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_LOGIN_EMAIL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Desert Haveli Admin <onboarding@resend.dev>

# Cloudinary. Keep the API secret server-only; never use it as VITE_...
VITE_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Media/admin API abuse protection. These are per-instance defaults; use a
# shared edge/store rate limiter before running multiple production instances.
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_ADMIN_WINDOW_SECONDS=60
RATE_LIMIT_ADMIN_MAX=30
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_MAX=10

# Admin PIN recovery. These values are server-only.
ADMIN_PIN_RECOVERY_OTP_TTL_SECONDS=600
ADMIN_PIN_RECOVERY_MAX_OTP_ATTEMPTS=5
